{
  "RabbitMQ": {
    "Enabled": true,
    "HostName": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "UserName": "guest",
    "Password": "guest",
    "QueueName": "audio_queue"
  },
  "WhisperPath": "../AI/whisper",
  "PiperPath": "../AI/piper",
  "Piper": {
    "Model": "en_US-lessac-medium.onnx"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "llama3"
  },
  "WorkDir": "audio_work",
  "FfmpegPath": "ffmpeg",
  "VoicePipeline": {
    "LogDirectory": "logs"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}