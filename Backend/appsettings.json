{
  "Server": {
    "Host": "10.17.254.58",
    "Port": 5000
  },
  "RabbitMQ": {
    "Enabled": true,
    "HostName": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "UserName": "guest",
    "Password": "guest",
    "QueueName": "audio_queue"
  },
  "MQTT": {
    "Enabled": true,
    "BrokerHost": "localhost",
    "BrokerPort": 1883,
    "ClientId": "jarvis-backend",
    "TopicIn": "jarvis/+/audio/in",
    "TopicOutTemplate": "jarvis/{0}/audio/out"
  },
  "Redis": {
    "Enabled": true,
    "Configuration": "localhost:6379",
    "InstanceName": "jarvis:",
    "RecentMemoryLimit": 20,
    "EmbeddingCacheTtlSeconds": 3600,
    "LlmCacheTtlMinutes": 10
  },
  "WhisperPath": "../AI/whisper",
  "PiperPath": "../AI/piper",
  "Piper": {
    "Model": "en_US-lessac-medium.onnx"
  },
  "Ollama": {
    "BaseUrl": "http://localhost:11434",
    "Model": "phi3:mini",
    "EmbeddingModel": "nomic-embed-text",
    "NumPredict": 50,
    "Temperature": 0.3,
    "TopK": 20,
    "TopP": 0.8
  },
  "MongoDB": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "jarvis",
    "MemoryCollectionName": "memory",
    "KnowledgeCollectionName": "knowledge",
    "RoleCollectionName": "roles"
  },
  "Memory": {
    "SearchLimit": 5
  },
  "Knowledge": {
    "SearchLimit": 5
  },
  "Assistant": {
    "Persona": "You are Jarvis, a helpful AI assistant inside a Spider-Man toy. You can speak in a friendly Spider-Man style occasionally, but DO NOT fully roleplay as Spider-Man. Focus on helping the user. Keep answers very short (1–2 sentences). Use previous conversation only if relevant.",
    "UserProfile": "The person you are talking to is Aravind. He is 24 years old, has completed MCA, and works as a software developer. Call him by name when relevant."
  },
  "WorkDir": "audio_work",
  "FfmpegPath": "ffmpeg",
  "VoicePipeline": {
    "LogDirectory": "logs"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}